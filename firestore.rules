rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: default-deny catch-all rule
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Helper function to validate document ID string format to prevent ID Hijacking & Path Poisoning
    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Helper function to restrict incoming payload size for DOS prevention (Denial of Wallet)
    function sizeConstraint(data) {
       return data.keys().size() <= 12;
    }

    // 2b. Custom Audit Log schema validation for strict integrity controls
    function isValidAuditLog(data) {
       return data.userId is string && data.userId.size() <= 128
           && data.userName is string && data.userName.size() <= 150
           && data.userRole is string && data.userRole.size() <= 100
           && data.action is string && data.action.size() <= 100
           && data.description is string && data.description.size() <= 1000
           && data.timestamp is string && data.timestamp.size() <= 60
           && data.userAgent is string && data.userAgent.size() <= 500
           && (!data.keys().contains('ipAddress') || data.ipAddress is string)
           && (!data.keys().contains('storeCode') || data.storeCode is string)
           && (!data.keys().contains('storeName') || data.storeName is string);
    }

    // 3. Custom User Document schemas validation
    function isValidUser(data) {
       return data.name is string && data.name.size() <= 100
           && data.username is string && data.username.size() <= 50
           && data.password is string && data.password.size() <= 100
           && data.role is string && data.role.size() <= 100;
    }

    // --- COLLECTION RULES ---

    // 0. Audit logs collection rules - STRICT APPEND-ONLY
    match /audit_logs/{logId} {
      allow list: if request.auth != null; 
      allow get: if request.auth != null && isValidId(logId);
      allow create: if request.auth != null && isValidId(logId) && request.resource.data.keys().size() <= 15 && isValidAuditLog(request.resource.data);
      allow update, delete: if false; // Immutability and security: once written, logs cannot be modified or deleted
    }

    // 1. Users collection rules
    match /users/{userId} {
      allow list: if request.auth != null; // Required by the lookup on custom login flow
      allow get: if request.auth != null && isValidId(userId);
      allow create, update: if request.auth != null && isValidId(userId) && sizeConstraint(request.resource.data) && isValidUser(request.resource.data);
      allow delete: if request.auth != null && isValidId(userId);
    }

    // 2. Stores collection rules
    match /stores/{storeId} {
      allow list: if request.auth != null;
      allow get: if request.auth != null && isValidId(storeId);
      allow create, update: if request.auth != null && isValidId(storeId) && sizeConstraint(request.resource.data) 
                            && request.resource.data.name is string && request.resource.data.name.size() <= 150
                            && request.resource.data.brand is string && request.resource.data.brand.size() <= 100;
      allow delete: if false; // Deletion is disabled for system store profiles
    }

    // 3. Store child collections and documents 
    match /stores/{storeId}/{collectionName}/{docId} {
      // General list/get access for operational panels
      allow list: if request.auth != null && isValidId(storeId);
      allow get: if request.auth != null && isValidId(storeId) && isValidId(docId);
      
      // Strict payload control and integrity enforcement for each subcollection
      allow create, update: if request.auth != null && isValidId(storeId) && isValidId(docId) 
                            && (
                              // Standard sub-resources containing a single 'data' item (e.g. checklists list, submissions, etc.)
                              (request.resource.data.keys().size() <= 10 && request.resource.data.keys().hasAll(['data']) && (request.resource.data.data is list || request.resource.data.data is map))
                              || 
                              // DRE operational period metrics (containing flat fields, higher field limit of 40)
                              (collectionName == "dre_periods" && request.resource.data.keys().size() <= 40 && request.resource.data.month is string)
                              || 
                              // CMV inventories and menu engineering lists (higher field limit of 20)
                              (collectionName == "cmv_periods" && request.resource.data.keys().size() <= 20 && request.resource.data.month is string && request.resource.data.year is string)
                            );
      
      // Operations are protected and restricted
      allow delete: if request.auth != null && isValidId(storeId) && isValidId(docId);
    }

    // 4. Backups administrative collection rules
    match /backups/{backupId} {
      allow list: if request.auth != null; 
      allow get: if request.auth != null && isValidId(backupId);
      allow create, update, delete: if request.auth != null && isValidId(backupId) && request.resource.data.keys().size() <= 15;
    }
  }
}
