{
  "entities": {
    "Store": {
      "title": "Store",
      "description": "Restaurant units",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "location": { "type": "string" },
        "code": { "type": "string" }
      },
      "required": ["id", "name", "brand"]
    },
    "CMVPeriod": {
      "title": "CMV Period Data",
      "description": "CMV and product margem data for a specific month/year",
      "type": "object",
      "properties": {
        "month": { "type": "string" },
        "year": { "type": "string" },
        "inventoryItems": { "type": "array" },
        "topProducts": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["month", "year", "inventoryItems", "topProducts"]
    },
    "User": {
      "title": "Application User",
      "description": "System user with specific role and permissions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "MANAGER", "FINANCIAL", "MANAGER_4ESTYLOS_MOSSORO", "MANAGER_BEBELU_MOSSORO", "MANAGER_BEBELU_RIOMAR_PAPICU"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "username", "password", "role"]
    },
    "ChecklistTemplates": {
      "title": "Checklist Templates",
      "description": "Templates for checklists in a store",
      "type": "object",
      "properties": {
        "data": { "type": "array" }
      },
      "required": ["data"]
    },
    "ChecklistSubmissions": {
      "title": "Checklist Submissions",
      "description": "Completed checklist submissions in a store",
      "type": "object",
      "properties": {
        "data": { "type": "array" }
      },
      "required": ["data"]
    },
    "ChecklistActionPlans": {
      "title": "Checklist Action Plans",
      "description": "Action plans generated from checklists in a store",
      "type": "object",
      "properties": {
        "data": { "type": "array" }
      },
      "required": ["data"]
    },
    "AccountsPayable": {
      "title": "Accounts Payable List",
      "description": "List of all accounts payable items for a store",
      "type": "object",
      "properties": {
        "data": { "type": "array" }
      },
      "required": ["data"]
    },
    "DailyControl": {
      "title": "Daily Control Data",
      "description": "Object containing arrays of daily expenses and vouchers",
      "type": "object",
      "properties": {
        "data": { "type": "object" }
      },
      "required": ["data"]
    },
    "Closings": {
      "title": "Store Closings",
      "description": "Faturamento and closings map for a store",
      "type": "object",
      "properties": {
        "data": { "type": "object" }
      },
      "required": ["data"]
    },
    "AuditLog": {
      "title": "Audit Log Entry",
      "description": "Secure append-only record of system events, logins, and configurations",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userRole": { "type": "string" },
        "action": { "type": "string" },
        "description": { "type": "string" },
        "storeCode": { "type": "string" },
        "storeName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" },
        "ipAddress": { "type": "string" },
        "metadata": { "type": "object" }
      },
      "required": ["userId", "userName", "userRole", "action", "description", "timestamp", "userAgent"]
    }
  },
  "firestore": {
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Global append-only audit trail collection"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Global collection of system users"
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Store profile"
    },
    "/stores/{storeId}/cmv_periods/{periodId}": {
      "schema": "CMVPeriod",
      "description": "Historical CMV data by period"
    },
    "/stores/{storeId}/dre_periods/{periodId}": {
      "schema": "object",
      "description": "DRE data by period"
    },
    "/stores/{storeId}/checklists/templates": {
      "schema": "ChecklistTemplates",
      "description": "Templates for store checklists"
    },
    "/stores/{storeId}/checklists/submissions": {
      "schema": "ChecklistSubmissions",
      "description": "Submitted checklists logs"
    },
    "/stores/{storeId}/checklists/action_plans": {
      "schema": "ChecklistActionPlans",
      "description": "Action plans logs"
    },
    "/stores/{storeId}/accounts_payable/all": {
      "schema": "AccountsPayable",
      "description": "All accounts payable items"
    },
    "/stores/{storeId}/daily_control/all": {
      "schema": "DailyControl",
      "description": "All daily expenses and employee advances"
    },
    "/stores/{storeId}/closings/all": {
      "schema": "Closings",
      "description": "All day-by-day cash closing logs"
    }
  }
}
